# ==========================================
# GPS-FREE-SAAS ENVIRONMENT CONFIGURATION
# ==========================================
# IMPORTANT: Replace ALL placeholder values before deployment!
# This file contains your system's configuration and secrets.

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# Database password - CHANGE THIS!
# Requirements: 12+ characters, mix of letters/numbers/symbols
DB_PASSWORD=ChangeThisToYourSecurePassword123

# Database connection URL (automatically uses DB_PASSWORD above)
DATABASE_URL=postgresql://gpsadmin:${DB_PASSWORD}@postgres:5432/gpstrack

# ==========================================
# JWT SECRET (Authentication Token)
# ==========================================
# JWT secret for securing authentication tokens
# GENERATE with: openssl rand -base64 32
# Requirements: 32+ characters, random string
JWT_SECRET=CHANGE_THIS_TO_OUTPUT_OF_openssl_rand_base64_32

# ==========================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ==========================================
# For email notifications and alerts
# Gmail requires an "App Password" (NOT your regular Gmail password)
# Get App Password at: https://myaccount.google.com/apppasswords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-gmail-app-password

# ==========================================
# GPS SERVER AUTHENTICATION
# ==========================================
# Secret key for GPS server authentication
# GENERATE with: openssl rand -base64 32
# Requirements: 32+ characters, random string
GPS_SERVER_KEY=CHANGE_THIS_TO_OUTPUT_OF_openssl_rand_base64_32

# ==========================================
# FRONTEND URLs
# ==========================================
# CHANGE localhost to YOUR SERVER IP ADDRESS
# Example: If your server IP is 3.108.114.12, use:
# FRONTEND_URL=http://3.108.114.12:3000
# NEXT_PUBLIC_API_URL=http://3.108.114.12:3001
# NEXT_PUBLIC_WS_URL=ws://3.108.114.12:3001

FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ==========================================
# OPTIONAL: WEB PUSH NOTIFICATIONS
# ==========================================
# Generate with: npx web-push generate-vapid-keys
# Leave empty if you don't need push notifications

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ==========================================
# DOMAIN (For SSL/HTTPS in Production)
# ==========================================
# Your domain name (optional, for SSL setup)
# Example: gps-tracking.yourdomain.com

DOMAIN=yourdomain.com

# ==========================================
# GPS DEVICE PORTS
# ==========================================
# These ports are configured in docker-compose
# Do NOT change unless you know what you're doing

GPS_GT06_PORT=5000
GPS_TK103_PORT=5001
GPS_H02_PORT=5002

# ==========================================
# NODE ENVIRONMENT
# ==========================================
# Keep this as "production" for deployment

NODE_ENV=production

# ==========================================
# CONFIGURATION CHECKLIST
# ==========================================
# Before running ./deploy.sh, make sure you've changed:
# 
# [REQUIRED]
# ☐ DB_PASSWORD - Your secure database password
# ☐ JWT_SECRET - Generated with: openssl rand -base64 32
# ☐ GPS_SERVER_KEY - Generated with: openssl rand -base64 32
# ☐ FRONTEND_URL - Replace localhost with YOUR_SERVER_IP
# ☐ NEXT_PUBLIC_API_URL - Replace localhost with YOUR_SERVER_IP
# ☐ NEXT_PUBLIC_WS_URL - Replace localhost with YOUR_SERVER_IP
#
# [OPTIONAL - For Email Features]
# ☐ SMTP_USER - Your Gmail address
# ☐ SMTP_PASS - Your Gmail app password
#
# ==========================================
# QUICK SETUP COMMANDS
# ==========================================
# Run these commands on your server to generate secrets:
#
# Generate DB_PASSWORD:
# openssl rand -base64 24
#
# Generate JWT_SECRET:
# openssl rand -base64 32
#
# Generate GPS_SERVER_KEY:
# openssl rand -base64 32
#
# Get your server IP:
# curl ifconfig.me
#
# ==========================================
# EXAMPLE CONFIGURATION (DO NOT USE AS-IS)
# ==========================================
# Here's what your .env should look like after editing:
#
# DB_PASSWORD=Xy9kL2mN4pQ6rS8tU0vW
# JWT_SECRET=aB3cD5eF7gH9iJ1kL3mN5oP7qR9sT1uV3wX5yZ7
# SMTP_USER=myemail@gmail.com
# SMTP_PASS=abcd efgh ijkl mnop
# GPS_SERVER_KEY=bC4dE6fG8hI0jK2lM4nO6pQ8rS0tU2vW4xY6zA8
# FRONTEND_URL=http://3.108.114.12:3000
# NEXT_PUBLIC_API_URL=http://3.108.114.12:3001
# NEXT_PUBLIC_WS_URL=ws://3.108.114.12:3001
#
# ==========================================
# SECURITY NOTES
# ==========================================
# 1. NEVER commit this file to Git
# 2. Use strong, unique passwords for DB_PASSWORD
# 3. Generate random secrets for JWT_SECRET and GPS_SERVER_KEY
# 4. Gmail app passwords are different from your regular password
# 5. Keep this file secure (chmod 600 .env)
#
# ==========================================
# GMAIL APP PASSWORD SETUP
# ==========================================
# 1. Go to: https://myaccount.google.com/security
# 2. Enable 2-Factor Authentication (if not already enabled)
# 3. Go to: https://myaccount.google.com/apppasswords
# 4. Select "Mail" and "Other (Custom name)"
# 5. Enter "GPS Tracking System"
# 6. Click "Generate"
# 7. Copy the 16-character password (format: xxxx xxxx xxxx xxxx)
# 8. Paste into SMTP_PASS above (with or without spaces)
#
# ==========================================
# HELP & TROUBLESHOOTING
# ==========================================
# If deployment fails with "variable not set":
# - Check that you've changed ALL required values above
# - Make sure there are no extra spaces around the = sign
# - Ensure DB_PASSWORD has no special characters like quotes
#
# For more help, see:
# - README.md
# - FINAL-DEPLOYMENT-GUIDE.md
# ==========================================
