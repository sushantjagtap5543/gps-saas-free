# ==========================================
# GPS-FREE-SAAS ENVIRONMENT CONFIGURATION
# ==========================================
# IMPORTANT: Replace placeholder values before deployment!

# Database Configuration
DB_PASSWORD=ChangeThisSecurePassword123!
DATABASE_URL=postgresql://gpsadmin:${DB_PASSWORD}@postgres:5432/gpstrack

# JWT Secret (Generate with: openssl rand -base64 32)
JWT_SECRET=CHANGE_THIS_32_CHAR_SECRET_KEY_RANDOMLY_GENERATED

# Email Configuration (Gmail SMTP)
# For Gmail: Use App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# GPS Server Configuration
GPS_SERVER_KEY=change_this_to_random_gps_server_auth_key_min_32_chars

# Frontend URLs (Replace with your server IP or domain)
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# For Production: Replace localhost with your IP/domain
# FRONTEND_URL=http://YOUR_SERVER_IP:3000
# NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:3001
# NEXT_PUBLIC_WS_URL=ws://YOUR_SERVER_IP:3001

# Optional: Web Push VAPID keys
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Domain (for production with SSL)
DOMAIN=yourdomain.com

# GPS Device Ports (configured in docker-compose)
GPS_GT06_PORT=5000
GPS_TK103_PORT=5001
GPS_H02_PORT=5002

# Node Environment
NODE_ENV=production
