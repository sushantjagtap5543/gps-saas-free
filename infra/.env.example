# ==========================================
# GPS-FREE-SAAS ENVIRONMENT CONFIGURATION
# ==========================================

# Database Configuration
DB_PASSWORD=your_secure_password_here_change_this
DATABASE_URL=postgresql://gpsadmin:${DB_PASSWORD}@postgres:5432/gpstrack

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=change_this_to_a_random_32_character_string

# Email Configuration (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_gmail_app_password_here

# GPS Server Configuration
GPS_SERVER_KEY=change_this_to_a_random_string_for_gps_server_auth

# Frontend URLs
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Optional: Web Push VAPID keys
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Domain (for production)
DOMAIN=yourdomain.com

# GPS Device Ports (configured in docker-compose)
GPS_GT06_PORT=5000
GPS_TK103_PORT=5001
GPS_H02_PORT=5002

# Node Environment
NODE_ENV=production
