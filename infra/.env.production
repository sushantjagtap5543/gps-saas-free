# ============================================
# GPS-FREE-SAAS PRODUCTION CONFIGURATION
# ============================================
# Generated: March 4, 2026
# Status: PRODUCTION READY ✅

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database

# Replace with your actual password (minimum 16 characters for production)
DB_PASSWORD=YourSecure32CharPasswordHere!@#$%^&*
DATABASE_URL=postgresql://gpsadmin:${DB_PASSWORD}@postgres:5432/gpstrack

# ============================================
# SECURITY CONFIGURATION
# ============================================

# JWT Secret Token
# Used for signing authentication tokens
# IMPORTANT: Change this to your own secure value in production!
# Provided secure token (64 characters):
JWT_SECRET=2muz93QfGa25xG3T5C8nfOWW960T6jhIn8KYxv4aY7ojY2YJNgY83lh0jdCsnWC8

# GPS Server Authentication Key
# Generate with: openssl rand -base64 32
# Used for GPS device authentication
GPS_SERVER_KEY=GenerateYourOwnSecure32CharacterKeyHere1234567890

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================

# SMTP Server (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Gmail Account Details
# Use your Gmail email address
SMTP_USER=your.email@gmail.com

# Gmail App Password (NOT your regular password)
# Generate here: https://myaccount.google.com/apppasswords
# Steps:
#   1. Enable 2-Factor Authentication
#   2. Go to App Passwords
#   3. Select "Mail" and "Windows Computer"
#   4. Copy the generated 16-character password
SMTP_PASS=xxxx xxxx xxxx xxxx

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Frontend URL (for CORS and redirects)
FRONTEND_URL=https://yourdomain.com

# Next.js Public API URL
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# WebSocket URL (for real-time updates)
NEXT_PUBLIC_WS_URL=wss://yourdomain.com

# ============================================
# WEB PUSH NOTIFICATIONS (Optional)
# ============================================
# Generate with: npx web-push generate-vapid-keys

# Public key for browser push notifications
VAPID_PUBLIC_KEY=

# Private key for signing push notifications
VAPID_PRIVATE_KEY=

# ============================================
# DOMAIN CONFIGURATION
# ============================================

# Your domain name (for SSL certificates, emails, etc.)
DOMAIN=yourdomain.com

# ============================================
# GPS DEVICE PORT CONFIGURATION
# ============================================

# GT06 Protocol Port (GT06, GT06N, JV200)
GPS_GT06_PORT=5000

# TK103 Protocol Port (TK103, TK103B, GPS103)
GPS_TK103_PORT=5001

# H02 Protocol Port (H02, JT600, GT02)
GPS_H02_PORT=5002

# ============================================
# ENVIRONMENT & RUNTIME
# ============================================

# Node Environment (development|production|staging)
NODE_ENV=production

# ============================================
# OPTIONAL: REDIS CONFIGURATION
# ============================================
# Redis is auto-configured in docker-compose
# Only modify if using external Redis

REDIS_URL=redis://redis:6379

# ============================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================

# 1. CHANGE ALL PLACEHOLDER VALUES:
#    - DB_PASSWORD: Use strong 32+ character password
#    - SMTP_USER: Your actual Gmail address
#    - SMTP_PASS: Your Gmail app password (not login password)
#    - DOMAIN: Your actual domain name
#    - JWT_SECRET: Keep the provided value or generate new one
#    - GPS_SERVER_KEY: Generate with: openssl rand -base64 32

# 2. SSL/HTTPS SETUP:
#    - Install certificate in /ssl directory
#    - Update Nginx configuration in /infra/nginx.conf
#    - Enable force-https in production

# 3. SECURITY CHECKLIST:
#    - [ ] JWT_SECRET is strong and unique
#    - [ ] DB_PASSWORD is 32+ characters
#    - [ ] SMTP credentials are correct
#    - [ ] FRONTEND_URL uses HTTPS
#    - [ ] NEXT_PUBLIC_WS_URL uses WSS (WebSocket Secure)
#    - [ ] Default credentials changed (admin@gps.com)
#    - [ ] Firewall rules properly configured
#    - [ ] SSL certificates installed
#    - [ ] Backups automated
#    - [ ] Monitoring enabled

# 4. INITIAL LOGIN (CHANGE IMMEDIATELY):
#    Email: admin@gps.com
#    Password: admin123
#    Demo: client@demo.com / client123

# 5. TESTING BEFORE PRODUCTION:
#    - [ ] API health check: curl https://yourdomain.com/api/health
#    - [ ] Frontend loads: https://yourdomain.com
#    - [ ] Login works with admin credentials
#    - [ ] WebSocket connects
#    - [ ] GPS data is received on port 5000-5002
#    - [ ] Emails are being sent
#    - [ ] Backups are running

# ============================================
# DOCKER COMPOSE DEPLOYMENT COMMAND
# ============================================

# 1. Copy this file to: ./infra/.env
# 2. Fill in all YOUR_VALUES
# 3. Run deployment:
#
# docker-compose -f docker-compose.prod.yml up -d --build
#
# 4. Verify services:
#
# docker-compose ps
# docker-compose logs -f
# curl https://yourdomain.com/api/health

# ============================================
# CONTAINER HEALTH CHECK
# ============================================

# Backend API Health: GET /health
# Expected Response: { "status": "ok", "timestamp": "...", "uptime": ... }

# Swagger API Docs: GET /api/docs
# Endpoint available at: https://yourdomain.com/api/docs

# Frontend: https://yourdomain.com
# Port: 3000 (internal), 80/443 (external via Nginx)

# ============================================
# MAINTENANCE
# ============================================

# Database Backup:
# docker-compose exec postgres pg_dump -U gpsadmin gpstrack > backup.sql

# Database Restore:
# docker-compose exec -T postgres psql -U gpsadmin gpstrack < backup.sql

# View Logs:
# docker-compose logs -f [service-name]

# Services: postgres, redis, gps-server, backend, web, nginx

# ============================================
# TROUBLESHOOTING
# ============================================

# Service won't start?
# 1. Check logs: docker-compose logs [service]
# 2. Verify environment variables are set
# 3. Check ports are not in use
# 4. Ensure database is running: docker-compose logs postgres

# Database connection failed?
# 1. Check DB_PASSWORD is correct
# 2. Verify PostgreSQL is healthy: docker-compose ps postgres
# 3. Test connection: docker-compose exec postgres pg_isready -U gpsadmin

# GPS data not arriving?
# 1. Check firewall rules allow ports 5000-5002
# 2. Verify device is configured to send data
# 3. Check logs: docker-compose logs gps-server
# 4. Test port: telnet YOUR_IP 5000

# WebSocket connection issues?
# 1. Check NEXT_PUBLIC_WS_URL is correct (should be wss:// for HTTPS)
# 2. Verify Nginx proxy_pass for WebSocket
# 3. Check browser console for connection errors

